{
  "manifest_version": 3,
  "name": "FocusGuard",
  "description": "A productivity focus timer with distraction alerts.",
  "version": "1.0.0",
  "permissions": ["alarms", "storage", "notifications", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "FocusGuard",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/activity-tracker.js",
        "content/inactivity-monitor.js",
        "content/website-monitor.js",
        "content/ui-manager.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
